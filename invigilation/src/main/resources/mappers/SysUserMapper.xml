<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.invigilation.invigilation.mapper.SysUserMapper">

    <select id="selectByUsername" resultType="com.invigilation.invigilation.entity.SysUser">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>

    <!-- 插入用户（适配sys_user表字段） -->
    <insert id="insert" parameterType="com.invigilation.invigilation.entity.SysUser">
        INSERT INTO sys_user (username, password, role)
        VALUES (#{username}, #{password}, #{role})
    </insert>
</mapper>